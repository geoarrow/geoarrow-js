{
  "name": "@geoarrow/geo-interface",
  "version": "0.4.0-beta.0",
  "description": "TypeScript interfaces for GeoArrow geometries — port of the Rust geo-traits crate.",
  "keywords": [
    "geoarrow",
    "geometry",
    "geo-traits",
    "geospatial",
    "typescript"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "author": "Kyle Barron <kylebarron2@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geoarrow/geoarrow-js.git",
    "directory": "packages/geo-interface"
  },
  "devDependencies": {
    "@geoarrow/test-fixtures": "workspace:*",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
